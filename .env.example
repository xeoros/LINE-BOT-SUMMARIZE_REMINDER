# LINE Bot Configuration
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token_here
LINE_CHANNEL_SECRET=your_line_channel_secret_here

# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/line_bot_db

# AI Configuration
AI_PROVIDER=claude  # Options: claude, openai, gemini, minimax, zai
CLAUDE_API_KEY=your_claude_api_key_here
CLAUDE_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_MODEL=abab6.5s-chat
ZAI_API_KEY=your_zai_api_key_here
ZAI_MODEL=zai-gpt-4

# Slack Configuration (Optional - required only if enable_slack=true)
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_APP_TOKEN=xapp-your-app-token-here  # Required for Events API mode
SLACK_SIGNING_SECRET=your-signing-secret-here

# MS Teams Configuration (Optional - required only if enable_teams=true)
TEAMS_APP_ID=your-app-id-here
TEAMS_APP_PASSWORD=your-app-password-here
TEAMS_TENANT_ID=your-tenant-id-here

# n8n Integration (Optional - required only for Teams incident reporting)
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/create-jira-incident

# Feature Flags (Optional)
ENABLE_LINE=true
ENABLE_SLACK=false
ENABLE_TEAMS=false
SLACK_INTEGRATION_MODE=both  # Options: webhook, events_api, both

# Server Configuration
PORT=3000

# Logging Configuration
LOG_LEVEL=info  # Options: trace, debug, info, warn, error

# Schedules Configuration
SCHEDULES_CONFIG_PATH=config/schedules.toml
